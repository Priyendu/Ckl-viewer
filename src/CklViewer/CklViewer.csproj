<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <AssemblyName>CklViewer</AssemblyName>
    <RootNamespace>CklViewer</RootNamespace>
    <Version>1.0.0</Version>
    <Authors>Priyendu</Authors>
    <Description>Ckl-viewer: DISA STIG checklist (.ckl / .cklb) viewer and editor with Vulnerator-style reporting.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="ClosedXML" Version="0.104.2" />
  </ItemGroup>

</Project>
