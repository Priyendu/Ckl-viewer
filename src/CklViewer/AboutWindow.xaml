<Window x:Class="CklViewer.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Ckl-viewer"
        Width="520" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Icon="/CklViewer;component/Assets/app.ico">
    <StackPanel Margin="24">
        <StackPanel Orientation="Horizontal">
            <Image Source="/CklViewer;component/Assets/app.ico" Width="56" Height="56" VerticalAlignment="Top" />
            <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="Ckl-viewer" FontSize="24" FontWeight="Bold" Foreground="#1F4E79" />
                <TextBlock x:Name="VersionText" Foreground="Gray" />
            </StackPanel>
        </StackPanel>

        <Border Background="#F3F6FA" CornerRadius="6" Padding="14" Margin="0,18,0,0">
            <StackPanel>
                <TextBlock x:Name="QuoteText" TextWrapping="Wrap" FontStyle="Italic" FontSize="13" />
                <TextBlock x:Name="QuoteAttribution" TextWrapping="Wrap" Foreground="Gray"
                           HorizontalAlignment="Right" Margin="0,6,0,0" FontSize="12" />
            </StackPanel>
        </Border>

        <TextBlock TextWrapping="Wrap" Margin="0,18,0,0" FontSize="13" LineHeight="20">
            This app exists because of a simple observation: the universe contained
            exactly zero applications that could open both <Bold>.ckl</Bold> and
            <Bold>.cklb</Bold> <Italic>and</Italic> still do what Vulnerator used to do.
            Nature abhors a vacuum. Assessors abhor it more.
        </TextBlock>

        <TextBlock TextWrapping="Wrap" Margin="0,12,0,0" FontSize="13" LineHeight="20">
            So it was written. Not because it was easy, but because the alternative
            was seventeen browser tabs and a spreadsheet named
            <Italic>final_FINAL_v3_actually_final.xlsx</Italic>.
        </TextBlock>

        <TextBlock Margin="0,18,0,0" FontSize="13">
            Crafted with C#, caffeine, and mild indignation by <Bold>Priyendu</Bold>.
        </TextBlock>

        <TextBlock Margin="0,6,0,0" FontSize="13" TextWrapping="Wrap">
            Released under the MIT License — because knowledge, like an unpatched
            vulnerability, wants to be free.
        </TextBlock>

        <TextBlock Margin="0,12,0,0" FontSize="13">
            <Hyperlink x:Name="RepoLink" RequestNavigate="RepoLink_RequestNavigate"
                       NavigateUri="https://github.com/Priyendu/Ckl-viewer">
                github.com/Priyendu/Ckl-viewer
            </Hyperlink>
        </TextBlock>

        <Button Content="It is what it is" Click="Close_Click" IsDefault="True" IsCancel="True"
                HorizontalAlignment="Right" Padding="16,6" Margin="0,18,0,0" />
    </StackPanel>
</Window>
